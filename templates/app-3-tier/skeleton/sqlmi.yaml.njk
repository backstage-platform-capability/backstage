# NOTE: Values are rendered by Backstage template. Do not edit placeholders manually.

# CAF-style names for RG & KV (derived from inputs)
resource_group_name: "rg-${{ values.regionShort }}-${{ values.appCode | lower }}-${{ values.environment | lower }}-001"

key_vault_name: "kv-${{ values.regionShort }}-${{ values.appCode | lower }}-${{ values.environment | lower }}-001"
key_vault_rg_name: "rg-${{ values.regionShort }}-${{ values.appCode | lower }}-${{ values.environment | lower }}-001"

mssql_managed_instances:
  # Primary instance
  - name: "sqlmi-${{ values.regionShort }}-${{ values.appCode | lower }}-${{ values.environment | lower }}-001"
    license_type: "${{ values.licenseType }}"
    location: "${{ values.azureRegion }}"
    sku_name: "${{ values.skuName }}"
    vcores: ${{ values.vcores }}
    storage_size_in_gb: ${{ values.storageSizeInGb }}

    {% if values.useStandardCafVnetNames %}
    subnet_name: "sn-${{ values.regionShort }}-sharedservices-${{ values.environment | lower }}"
    vnet_name: "vnet-${{ values.regionShort }}-${{ values.appCode | lower }}-${{ values.environment | lower }}-001"
    {% else %}
    subnet_name: "${{ values.existingSubnetName }}"
    vnet_name: "${{ values.existingVnetName }}"
    {% endif %}

    vnet_rg_name: {% if values.vnetResourceGroupName %}"{{ values.vnetResourceGroupName }}"{% else %}null{% endif %}

    administrator_login: "${{ values.administratorLogin }}"
    admin_login_username_secret_name: "${{ values.administratorLogin }}-username"
    admin_login_password_secret_name: "${{ values.administratorLogin }}-password"
    secret_expiration_date: {% if values.secretExpirationDate %}"{{ values.secretExpirationDate }}"{% else %}null{% endif %}
    collation: null
    proxy_override: null
    public_data_endpoint_enabled: false
    storage_account_type: "LRS"
    timezone_id: null
    identity:
      type: "SystemAssigned"
    failover_instance: false
    primary_instance_name: null

  {% if values.enableFailover %}
  # Secondary (failover) instance
  - name: "sqlmi-${{ values.regionShort }}-${{ values.appCode | lower }}-${{ values.environment | lower }}-002"
    license_type: "${{ values.licenseType }}"
    location: "${{ values.azureRegion }}"
    sku_name: "${{ values.skuName }}"
    vcores: ${{ values.vcores }}
    storage_size_in_gb: ${{ values.storageSizeInGb }}

    {% if values.useStandardCafVnetNames %}
    subnet_name: "sn-${{ values.regionShort }}-sharedservices-${{ values.environment | lower }}"
    vnet_name: "vnet-${{ values.regionShort }}-${{ values.appCode | lower }}-${{ values.environment | lower }}-001"
    {% else %}
    subnet_name: "${{ values.existingSubnetName }}"
    vnet_name: "${{ values.existingVnetName }}"
    {% endif %}

    vnet_rg_name: {% if values.vnetResourceGroupName %}"{{ values.vnetResourceGroupName }}"{% else %}null{% endif %}

    administrator_login: "${{ values.administratorLogin }}"
    admin_login_username_secret_name: "${{ values.administratorLogin }}2-username"
    admin_login_password_secret_name: "${{ values.administratorLogin }}2-password"
    secret_expiration_date: {% if values.secretExpirationDate %}"{{ values.secretExpirationDate }}"{% else %}null{% endif %}
    collation: null
    proxy_override: null
    public_data_endpoint_enabled: false
    storage_account_type: "LRS"
    timezone_id: null
    identity:
      type: "SystemAssigned"
    failover_instance: true
    primary_instance_name: "sqlmi-${{ values.regionShort }}-${{ values.appCode | lower }}-${{ values.environment | lower }}-001"
  {% endif %}

# Databases created on the primary MI
{% if values.databaseNames and values.databaseNames | length > 0 %}
databases:
{% for db in values.databaseNames %}
  - name: "{{ db }}"
    managed_instance_name: "sqlmi-${{ values.regionShort }}-${{ values.appCode | lower }}-${{ values.environment | lower }}-001"
{% endfor %}
{% else %}
databases: []
{% endif %}

# AAD admin assignment for the primary MI
aad_admin:
  managed_instance_name: "sqlmi-${{ values.regionShort }}-${{ values.appCode | lower }}-${{ values.environment | lower }}-001"
  login_username: "${{ values.administratorLogin }}"
  users: [{% if values.adminUsers %}{% for u in values.adminUsers %}"{{ u }}"{% if not loop.last %}, {% endif %}{% endfor %}{% endif %}]
  service_principal_names: []
  group_names: []
  azuread_authentication_only: ${{ values.azureAdAuthOnly | default(false) }}

# Failover group
{% if values.enableFailover %}
failover_group:
  name: "fg-${{ values.regionShort }}-${{ values.appCode | lower }}-${{ values.environment | lower }}-001"
  managed_instance_name: "sqlmi-${{ values.regionShort }}-${{ values.appCode | lower }}-${{ values.environment | lower }}-001"
  failover_managed_instance_name: "sqlmi-${{ values.regionShort }}-${{ values.appCode | lower }}-${{ values.environment | lower }}-002"
  readonly_endpoint_failover_policy_enabled: false
  failover_policy_mode: "Automatic"
  failover_grace_minutes: 60
{% else %}
failover_group: {}
{% endif %}

# Additional tags
tags:
  environment: "${{ values.environment }}"
  application: "${{ values.appCode }}"